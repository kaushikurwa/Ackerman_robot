<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="wheel_radius"    value="0.05027"/>
  <xacro:property name="wheel_length"    value="0.03"/>
  <xacro:property name="chassis_x"      value="0.35"/>
  <xacro:property name="chassis_y"      value="0.15"/>
  <xacro:property name="chassis_z"      value="0.08"/>

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0.01 0 0.05" rpy="0 0 0"/>
      <geometry><box size="${chassis_x} ${chassis_y} ${chassis_z}"/></geometry>
      <material name="blue"><color rgba="0.2 0.2 0.8 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.01 0 0.05" rpy="0 0 0"/>
      <geometry><box size="${chassis_x} ${chassis_y} ${chassis_z}"/></geometry>
    </collision>
    <xacro:box_inertia m="1.8886"
                       x="${chassis_x}" y="${chassis_y}" z="${chassis_z}"
                       o_xyz="0.0115 0 0.0687" o_rpy="0 0 0"/>
  </link>

  <joint name="base_joint" type="fixed">
    <origin xyz="-0.0117 0 0.02677" rpy="0 0 0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <link name="FL_STEERING_LINK">
    <xacro:box_inertia m="0.0038" x="0.01" y="0.01" z="0.01"
                       o_xyz="-0.0029 0 0" o_rpy="0 0 0"/>
  </link>

  <joint name="FL_STEERING_JOINT" type="revolute">
    <origin xyz="0.16174 0.085 0.0235" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="FL_STEERING_LINK"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.524" upper="0.524" effort="5" velocity="3"/>
  </joint>

  <link name="FL_WHEEL_LINK">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_length}"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_length}"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="0.0635" r="${wheel_radius}" l="${wheel_length}"
                            o_xyz="0 0 0" o_rpy="1.5707963 0 0"/>
  </link>

  <joint name="FL_WHEEL_JOINT" type="continuous">
    <origin xyz="0 0.0245 0" rpy="0 0 0"/>
    <parent link="FL_STEERING_LINK"/>
    <child link="FL_WHEEL_LINK"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="FR_STEERING_LINK">
    <xacro:box_inertia m="0.0047" x="0.01" y="0.01" z="0.01"
                       o_xyz="0.0015 0 0" o_rpy="0 0 0"/>
  </link>

  <joint name="FR_STEERING_JOINT" type="revolute">
    <origin xyz="0.16174 -0.085 0.0235" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="FR_STEERING_LINK"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.524" upper="0.524" effort="5" velocity="3"/>
  </joint>

  <link name="FR_WHEEL_LINK">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_length}"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_length}"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="0.0635" r="${wheel_radius}" l="${wheel_length}"
                            o_xyz="0 0 0" o_rpy="1.5707963 0 0"/>
  </link>

  <joint name="FR_WHEEL_JOINT" type="continuous">
    <origin xyz="0 -0.0245 0" rpy="0 0 0"/>
    <parent link="FR_STEERING_LINK"/>
    <child link="FR_WHEEL_LINK"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="BL_WHEEL_LINK">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_length}"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_length}"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="0.0616" r="${wheel_radius}" l="${wheel_length}"
                            o_xyz="0 0 0" o_rpy="1.5707963 0 0"/>
  </link>

  <joint name="BL_WHEEL_JOINT" type="continuous">
    <origin xyz="-0.13328 0.1093 0.02075" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="BL_WHEEL_LINK"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="BR_WHEEL_LINK">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_length}"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_length}"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="0.0616" r="${wheel_radius}" l="${wheel_length}"
                            o_xyz="0 0 0" o_rpy="1.5707963 0 0"/>
  </link>

  <joint name="BR_WHEEL_JOINT" type="continuous">
    <origin xyz="-0.13328 -0.1093 0.02075" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="BR_WHEEL_LINK"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="CAMERA_LINK">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.06 0.02"/></geometry>
      <material name="red"><color rgba="0.8 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.06 0.02"/></geometry>
    </collision>
    <xacro:box_inertia m="0.0548" x="0.02" y="0.06" z="0.02"
                       o_xyz="0 0 0" o_rpy="0 0 0"/>
  </link>

  <link name="CAMERA_LINK_OPTICAL"/>

  <joint name="CAMERA_JOINT" type="fixed">
    <origin xyz="0.15 0.0 0.2" rpy="0 0.1 0"/>
    <parent link="base_link"/>
    <child link="CAMERA_LINK"/>
  </joint>

  <joint name="CAMERA_OPTICAL_JOINT" type="fixed">
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
    <parent link="CAMERA_LINK"/>
    <child link="CAMERA_LINK_OPTICAL"/>
  </joint>

</robot>